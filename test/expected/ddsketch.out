 0.10 | t           | 
 0.20 | t           | 
 0.30 | t           | 
 0.40 | t           | 
 0.50 | t           | 
 0.60 | t           | 
 0.70 | t           | 
 0.80 | t           | 
 0.90 | t           | 
 1.00 | t           | 
